#!/usr/bin/env ruby

require 'x_aeon_agents_skills'

session_id = ARGV[0]

XAeonAgentsSkills::Configuration.configure(**XAeonAgentsSkills::Helpers.keys_from_launcher)
ReadmeGeneratorAgent.new(session_id:).run(
  gen_about: true,
  gen_quick_start: true,
  gen_requirements: true,
  gen_features: true,
  gen_public_api: true,
  gen_documentation: true,
  gen_how_it_works: true,
  gen_development: true,
  gen_contributing: true,
  gen_license: true
)
