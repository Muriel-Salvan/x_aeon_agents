#!/usr/bin/env ruby

require 'x_aeon_agents'

session_id = ARGV[0]

XAeonAgents::Configuration.configure(**XAeonAgents::Helpers.keys_from_launcher)
XAeonAgents::Agents::ReadmeGeneratorAgent.new(session_id:).run(
  gen_about: true,
  gen_quick_start: true,
  gen_requirements: true,
  gen_features: true,
  gen_public_api: true,
  gen_documentation: true,
  gen_how_it_works: true,
  gen_development: true,
  gen_contributing: true,
  gen_license: true
)
