#!/usr/bin/env ruby

# Parameters:
# * *prompt* (String): The prompt to give to the AI agent
prompt = ARGV[0]

require 'x_aeon_agents_skills'

XAeonAgentsSkills::Configuration.configure(**XAeonAgentsSkills::Helpers.keys_from_launcher)
agent = ExecutorAgent.new(**XAeonAgentsSkills::Models.free_simple)
agent.run(user_instructions: prompt)
puts agent.conversation.last[:message]
