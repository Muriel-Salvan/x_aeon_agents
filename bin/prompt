#!/usr/bin/env ruby

# Parameters:
# * *prompt* (String): The prompt to give to the AI agent
prompt = ARGV[0]

require 'x_aeon_agents'

XAeonAgents::Configuration.configure(**XAeonAgents::Helpers.keys_from_launcher)
agent = XAeonAgents::Agents::ExecutorAgent.new(**XAeonAgents::Models.free_simple)
agent.run(user_instructions: prompt)
puts agent.conversation.last[:message]
