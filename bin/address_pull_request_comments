#!/usr/bin/env ruby

# Parameters:
# * *pull_request_number* (Integer): The Pull Request number to look for comments
# * *session_id* (String): [Optional] The session ID for persistence
pull_request_number = Integer(ARGV[0])
session_id = ARGV[1]

require 'x_aeon_agents'

XAeonAgents::Configuration.configure(**XAeonAgents::Helpers.keys_from_launcher)
XAeonAgents::Agents::ReviewResolverAgent.new(session_id:).run(pull_request_number:)
